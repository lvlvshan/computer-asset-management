# 服务器端口（默认 3000）
PORT=3000

# JWT 签名密钥 - 生产环境请修改为高强度随机字符串
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production

# 后端服务地址（采集脚本自动生成时使用的服务器地址）
# 留空则自动检测局域网 IP
BASE_URL=

# 运行环境 (development / production)
NODE_ENV=development

# 审批自动创建用户时的默认密码（采集脚本上传 userName 时）
DEFAULT_USER_PASSWORD=Chang3MePl3ase!

# SQLite 数据库路径（Docker 部署时改为 file:/data/dev.db 并挂载卷）
# 相对路径基于 CWD（backend/ 目录），即 backend/prisma/dev.db
DATABASE_URL=file:./prisma/dev.db
